generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               String           @id @default(uuid())
  itemNumber       String           @unique
  name             String
  brand            String?
  description      String?
  isAvailable      Boolean          @default(true)
  alternativeNames Json?
  tags             Json? // ["tag1", "tag2", ...]
  categoryId       String?
  category         Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  productImages    ProductImage[]
  variants         Variant[]
  productPrices    ProductPrice[]
  orderItems       OrderItem[]
  notifications    AiNotification[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  icon        String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  itemNumber  String?   @unique
  products    Product[]
}

model Person {
  id              String             @id @default(uuid())
  name            String?
  address         String?
  notes           String?
  personTypeId    String?
  personType      PersonType?        @relation(fields: [personTypeId], references: [id], onDelete: SetNull)
  source          String?
  contacts        Contact[]
  tags            Json? // ["tag1", "tag2"]
  currencies      Json? // ["currency-uuid-1", "currency-uuid-2"]
  groupName       String?
  groupNumber     String?            @unique
  isActive        Boolean            @default(true)
  lastInteraction DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  priceLabels     PersonPriceLabel[]
  orders          Order[]
  notifications   AiNotification[]

  @@map("Person")
}

// Pure image storage — no product-specific data
model MediaImage {
  id            String         @id @default(uuid())
  url           String
  filename      String
  alt           String?
  sizeBytes     Int?
  width         Int?
  height        Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  productImages ProductImage[]
}

// Junction table: links products to images
model ProductImage {
  id           String     @id @default(uuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaImageId String
  mediaImage   MediaImage @relation(fields: [mediaImageId], references: [id], onDelete: Cascade)
  variants     Variant[]  @relation("VariantToProductImages")
  isPrimary    Boolean    @default(false)
  order        Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([productId, mediaImageId])
}

// Variants table: colors, sizes, custom variants
model Variant {
  id            String         @id @default(uuid())
  variantNumber String         @unique // "001-BF-483-01" — globally unique
  suffix        String // "01", "أسود", "XL" — user-entered 4th segment
  name          String // display name
  type          String         @default("color") // "color" | "size" | "custom"
  hex           String? // CSS hex color (for type=color only)
  price         Float? // Variant-specific price override
  order         Int            @default(0)
  isDefault     Boolean        @default(false)
  productId     String
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  variantImages ProductImage[] @relation("VariantToProductImages")
  orderItems    OrderItem[]

  @@unique([productId, suffix])
}

// Price label names for product pricing
model PriceLabel {
  id            String             @id @default(uuid())
  itemNumber    String             @unique
  name          String             @unique
  notes         String?
  persons       PersonPriceLabel[]
  productPrices ProductPrice[]
  orderItems    OrderItem[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

// Explicit join table for Person <-> PriceLabel
model PersonPriceLabel {
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId     String
  priceLabel   PriceLabel @relation(fields: [priceLabelId], references: [id], onDelete: Cascade)
  priceLabelId String

  assignedAt DateTime @default(now())

  @@id([personId, priceLabelId])
}

// Person type classifications
model PersonType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  color       String?  @default("#64748b")
  icon        String?  @default("User")
  notes       String?
  isDefault   Boolean  @default(false)
  persons     Person[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Contact information (phone, email, whatsapp) — normalized
model Contact {
  id        String   @id @default(uuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  type      String // "phone" | "email" | "whatsapp"
  value     String // the actual number or email
  label     String? // "جوال", "عمل", etc.
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([type, value])
}

// Currency management
model Currency {
  id            String         @id @default(uuid())
  itemNumber    String         @unique
  name          String         @unique // e.g. "ريال يمني"
  code          String         @unique // e.g. "YER"
  symbol        String // e.g. "ر.ي"
  isDefault     Boolean        @default(false)
  isActive      Boolean        @default(true)
  productPrices ProductPrice[]
  orderItems    OrderItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Product prices — normalized pricing with multi-currency support
model ProductPrice {
  id           String     @id @default(uuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceLabelId String
  priceLabel   PriceLabel @relation(fields: [priceLabelId], references: [id], onDelete: Cascade)
  currencyId   String
  currency     Currency   @relation(fields: [currencyId], references: [id], onDelete: Restrict)
  value        Float
  unit         String? // e.g. "حبة", "كرتون"
  quantity     Int? // number of units
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([productId, priceLabelId, currencyId])
}

// Represents a customer order
model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique // auto-generated e.g. "0001"
  personId    String?
  person      Person?     @relation(fields: [personId], references: [id], onDelete: SetNull)
  status      String      @default("pending")
  // "pending" | "confirmed" | "processing" | "shipped" | "delivered" | "cancelled"
  notes       String?
  totalAmount Float? // pre-computed sum from items
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// Individual line items inside an order
model OrderItem {
  id           String      @id @default(uuid())
  orderId      String
  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId    String?
  variant      Variant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)
  priceLabelId String?
  priceLabel   PriceLabel? @relation(fields: [priceLabelId], references: [id], onDelete: SetNull)
  // Snapshot of price & currency from ProductPrice at order creation time
  unitPrice    Float
  currencyId   String?
  currency     Currency?   @relation(fields: [currencyId], references: [id], onDelete: SetNull)
  quantity     Int         @default(1)
  notes        String?
  createdAt    DateTime    @default(now())
}

// AI-driven notifications from bot product searches
model AiNotification {
  id            String    @id @default(uuid())
  type          String // "out_of_stock" | "not_found"
  searchQuery   String
  productId     String?
  product       Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName   String?
  personId      String?
  person        Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)
  source        String?   @default("bot") // "bot" | "api"
  phoneNumber   String?
  isRead        Boolean   @default(false)
  isArchived    Boolean   @default(false)
  archivedAt    DateTime?
  archiveReason String?
  createdAt     DateTime  @default(now())

  @@index([isRead])
  @@index([isArchived])
  @@index([type])
  @@index([createdAt])
  @@index([personId])
}

// User accounts for dashboard authentication
model User {
  id        String    @id @default(uuid())
  name      String
  username  String    @unique
  password  String // bcrypt hashed
  role      String    @default("user") // "admin" | "user"
  color     String    @default("#6366f1") // avatar color
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Store settings — singleton row (id = "default")
model StoreSettings {
  id           String   @id @default("default")
  name         String   @default("المتجر الرئيسي")
  description  String?
  logo         String?  // URL path to uploaded logo image
  favicon      String?  // URL path to uploaded favicon
  phone        String?
  email        String?
  whatsapp     String?
  website      String?
  address      String?
  city         String?
  country      String?
  workingHours Json?    // { "sun": "8:00-17:00", ... }
  socialLinks  Json?    // { "facebook": "...", "instagram": "...", ... }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
